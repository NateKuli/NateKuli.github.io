-- ============================================================
-- VIEW: ActiveOrders
-- ============================================================

CREATE VIEW ActiveOrders AS
SELECT 
    o.OrderID,
    c.FirstName,
    c.LastName,
    o.SKU,
    o.Description
FROM Orders o
JOIN Collaborators c ON o.CollaboratorID = c.CollaboratorID;

